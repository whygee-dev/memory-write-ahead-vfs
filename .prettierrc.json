{
  "printWidth": 120,
  "semi": true,
  "singleQuote": true,
  "trailingComma": "es5",
  "overrides": [
    {
      "files": "*.{ts,tsx,js,jsx,mjs,cjs}",
      "options": {
        "tabWidth": 4
      }
    },
    {
      "files": "*.{json,md,html,yml,yaml}",
      "options": {
        "tabWidth": 2
      }
    }
  ]
}
